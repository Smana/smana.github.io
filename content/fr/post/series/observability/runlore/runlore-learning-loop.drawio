<mxfile host="app.diagrams.net" agent="drawio" version="24.7.7">
  <diagram id="runlore-learning-loop" name="learning-loop">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1060" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="logo" value="" style="shape=image;imageAspect=0;aspect=fixed;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="138" height="49" as="geometry" />
        </mxCell>
        <mxCell id="title" value="&#8212; the learning loop" style="text;html=1;fontStyle=1;fontSize=27;fontColor=#0F172A;fontFamily=Helvetica;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="196" y="8" width="640" height="48" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Retrieve either scores a recall hit &#8212; an instant answer, no investigation &#8212; or misses and runs the full loop that feeds a catalog you own." style="text;html=1;fontStyle=2;fontSize=15;fontColor=#475569;fontFamily=Helvetica;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="990" height="24" as="geometry" />
        </mxCell>

        <mxCell id="n-retrieve" value="&#9312; &lt;b&gt;Retrieve&lt;/b&gt;&lt;br&gt;recall a trusted past answer from the KB" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=10;shadow=1;fillColor=#EEF2FF;strokeColor=#6366F1;strokeWidth=2;fontColor=#312E81;fontFamily=Helvetica;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="375" y="108" width="290" height="108" as="geometry" />
        </mxCell>
        <mxCell id="n-capture" value="&#9313; &lt;b&gt;Capture&lt;/b&gt;&lt;br&gt;investigate live &#183; record the outcome&lt;br&gt;&lt;i&gt;(did the incident resolve?)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=10;shadow=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=2;fontColor=#78350F;fontFamily=Helvetica;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="740" y="336" width="290" height="108" as="geometry" />
        </mxCell>
        <mxCell id="n-curate" value="&#9314; &lt;b&gt;Curate&lt;/b&gt;&lt;br&gt;a novel, verified finding &#8594; reviewed PR&lt;br&gt;&lt;i&gt;in a repo you own&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=10;shadow=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#4C1D95;fontFamily=Helvetica;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="375" y="564" width="290" height="108" as="geometry" />
        </mxCell>
        <mxCell id="n-compound" value="&#9315; &lt;b&gt;Compound&lt;/b&gt;&lt;br&gt;merged PR re-indexed&lt;br&gt;&#8594; the catalog gets denser" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=10;shadow=1;fillColor=#CCFBF1;strokeColor=#0D9488;strokeWidth=2;fontColor=#134E4A;fontFamily=Helvetica;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="10" y="336" width="290" height="108" as="geometry" />
        </mxCell>

        <mxCell id="n-instant" value="&#9889; &lt;b&gt;Instant answer in chat&lt;/b&gt;&lt;br&gt;no investigation, no new PR" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=12;shadow=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=2.5;fontColor=#064E3B;fontFamily=Helvetica;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="375" y="336" width="290" height="108" as="geometry" />
        </mxCell>

        <mxCell id="n-catalog" value="&#128218; &lt;b&gt;A catalog you own&lt;/b&gt; &#183; OKF markdown &#183; PR-reviewed&lt;br&gt;confidence tracks the observed &lt;i&gt;resolve-rate&lt;/i&gt; &#8212; entries that stop resolving decay" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;dashed=1;fillColor=#F8FAFC;strokeColor=#94A3B8;strokeWidth=1.5;fontColor=#334155;fontFamily=Helvetica;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="170" y="694" width="720" height="52" as="geometry" />
        </mxCell>

        <mxCell id="e-hit" value="recall hit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#059669;strokeWidth=3;endArrow=classic;endFill=1;fontStyle=1;fontColor=#047857;fontFamily=Helvetica;fontSize=15;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n-retrieve" target="n-instant">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="54" y="0" as="offset" />
          </mxGeometry>
        </mxCell>

        <mxCell id="e-miss" value="recall miss" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7C3AED;strokeWidth=2;endArrow=classic;endFill=1;fontColor=#6D28D9;fontFamily=Helvetica;fontSize=15;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n-retrieve" target="n-capture">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-nv" value="novel + verified" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7C3AED;strokeWidth=2;endArrow=classic;endFill=1;fontColor=#6D28D9;fontFamily=Helvetica;fontSize=15;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n-capture" target="n-curate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-merge" value="a human merges the PR" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7C3AED;strokeWidth=2;endArrow=classic;endFill=1;fontColor=#6D28D9;fontFamily=Helvetica;fontSize=15;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="n-curate" target="n-compound">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-loop" value="re-indexed &#8594; recall-able next time" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#7C3AED;strokeWidth=2;endArrow=classic;endFill=1;fontColor=#6D28D9;fontFamily=Helvetica;fontSize=15;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n-compound" target="n-retrieve">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
