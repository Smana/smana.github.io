        <!-- ============ ANNOTATION CENTRALE ============ -->
        <mxCell id="key" value="💡 &lt;b&gt;Les deux branches pointent le même &lt;span style=&#39;font-family:monospace&#39;&gt;Backend&lt;/span&gt;&lt;/b&gt; — donc le même Service, le même pod, le même GPU.&lt;br&gt;Le canary n&#39;envoie rien « ailleurs » : &lt;span style=&#39;font-family:monospace&#39;&gt;modelNameOverride&lt;/span&gt; &lt;b&gt;réétiquette&lt;/b&gt; 10 % des requêtes avant qu&#39;elles n&#39;atteignent vLLM,&lt;br&gt;qui a déjà l&#39;adapter en mémoire. &lt;b&gt;Zéro GPU supplémentaire : aucun réplica de plus, aucun nœud de plus.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;fontSize=16;fontColor=#333333;align=center;verticalAlign=middle;" vertex="1" parent="1">
